---
import "../styles/global.css";
import "@fontsource/geist-sans";
import Footer from "../components/Footer.astro";

interface Props {
  title?: string;
  lang?: string;
  description?: string;
  canonicalUrl?: string;
  jsonLd?: object;
}

const {
  title = "Pere Montpeó",
  lang = "ca",
  description = "Lloc web i blog de Pere Montpeó. Enginyer de programari especialitzat en desenvolupament web.",
  canonicalUrl,
  jsonLd,
} = Astro.props as Props;
const siteUrl = "https://peremontpeo.dev";
const pageUrl = canonicalUrl || siteUrl;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={pageUrl} />
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="Pere Montpeó" />
    <link rel="manifest" href="/site.webmanifest" />
    <title>{title}</title>
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:image" content={`${siteUrl}/api/og-image/default.png`} />
    <meta property="og:locale" content="ca_ES" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta
      name="twitter:image"
      content={`${siteUrl}/api/og-image/default.png`}
    />
    {
      jsonLd && (
        <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
      )
    }
    <meta
      name="theme-color"
      content="#f7f7f8"
      media="(prefers-color-scheme: light)"
    />
    <meta
      name="theme-color"
      content="#070708"
      media="(prefers-color-scheme: dark)"
    />
    <slot name="head" />

    <script is:inline>
      // Evita FOUC: aplica el tema desat abans de pintar.
      // Estats: 'light' | 'dark' | 'system'(=auto). Auto deixa actuar light-dark().
      (function () {
        try {
          const t = localStorage.getItem("theme");
          const root = document.documentElement;
          if (t === "light" || t === "dark") root.setAttribute("data-theme", t);
          else root.removeAttribute("data-theme");
        } catch {
          /* localStorage no disponible */
        }
      })();
    </script>
    <style is:inline>
      /* Anti-FOUC: garanteix el color de fons correcte abans del CSS principal */
      :root[data-theme="dark"] {
        background-color: oklch(7% 0.005 260);
        color: oklch(97% 0.003 250);
      }
      :root[data-theme="light"] {
        background-color: oklch(97% 0.003 250);
        color: oklch(20% 0.004 250);
      }
      @media (prefers-color-scheme: dark) {
        :root:not([data-theme]) {
          background-color: oklch(7% 0.005 260);
          color: oklch(97% 0.003 250);
        }
      }
      @media (prefers-color-scheme: light) {
        :root:not([data-theme]) {
          background-color: oklch(97% 0.003 250);
          color: oklch(20% 0.004 250);
        }
      }
    </style>
  </head>
  <body>
    <a href="#main" class="skip-link">Vés al contingut</a>
    <div class="frame">
      <main id="main">
        <slot />
      </main>
      <Footer />
    </div>
  </body>
</html>

<script>
  function applyTheme(value: "light" | "dark" | "system") {
    const root = document.documentElement;
    if (value === "light" || value === "dark")
      root.setAttribute("data-theme", value);
    else root.removeAttribute("data-theme");
  }

  function init() {
    const set = (v: "light" | "dark" | "system") => {
      try {
        localStorage.setItem("theme", v);
      } catch {
        /* localStorage no disponible */
      }
      applyTheme(v);
    };
    document
      .getElementById("light-theme-button")
      ?.addEventListener("click", () => set("light"));
    document
      .getElementById("dark-theme-button")
      ?.addEventListener("click", () => set("dark"));
    document
      .getElementById("system-theme-button")
      ?.addEventListener("click", () => set("system"));
  }

  document.addEventListener("DOMContentLoaded", init);
</script>

<style>
  html,
  body {
    margin: 0;
    padding: 0;
  }

  body {
    padding: 30px;
    min-height: 100vh;
  }

  @media (min-width: 640px) {
    body {
      padding: 40px;
    }
  }

  .frame {
    max-width: 46rem;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    min-height: calc(100vh - 60px);
  }

  @media (min-width: 640px) {
    .frame {
      min-height: calc(100vh - 80px);
    }
  }

  main {
    flex: 1 0 auto;
  }

  @media print {
    body {
      padding: 0;
    }
    .frame {
      max-width: 100%;
      min-height: auto;
      display: block;
    }
  }
</style>
