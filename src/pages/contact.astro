---
import Layout from "../layouts/Layout.astro";
import InteractiveAvatar from "../components/InteractiveAvatar.astro";
import ContactSection from "../components/ContactSection.astro";
---

<Layout
  title="Contacte | Pere Montpeó"
  description="Contacta amb Pere Montpeó. Formes de contacte per col·laboracions, preguntes o projectes."
  canonicalUrl="https://peremontpeo.dev/contact/"
>
  <div class="home-avatar animate"><InteractiveAvatar /></div>

  <h1 class="title page-title">CONTACTE</h1>
  <p class="muted intro">
    Tens alguna pregunta o vols col·laborar? Aquí tens com pots contactar-me.
  </p>

  <p class="tilde" aria-hidden="true">~~~</p>

  <ContactSection />
</Layout>

<style>
  .home-avatar {
    margin-bottom: 24px;
  }
  .page-title {
    font-size: 1.4rem;
    margin: 0 0 0.5rem;
    text-transform: uppercase;
  }
  .intro {
    margin: 0;
    max-width: 60ch;
  }
</style>
