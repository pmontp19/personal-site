---
import Layout from "../layouts/Layout.astro";
import InteractiveAvatar from "../components/InteractiveAvatar.astro";
import ContactSection from "../components/ContactSection.astro";
---

<Layout title="Contacte | Pere Montpeó" description="Contacta amb Pere Montpeó. Formes de contacte per col·laboracions, preguntes o projectes." canonicalUrl="https://peremontpeo.dev/contact/">
  <main class="section">
    <div class="contact-header">
      <InteractiveAvatar />
      <p class="subtitle animate" style="animation-delay: 0.1s;">
        Tens alguna pregunta o vols col·laborar? Aquí tens com pots
        contactar-me.
      </p>
    </div>

    <div class="contact-content animate" style="animation-delay: 0.2s;">
      <ContactSection />
    </div>
  </main>
</Layout>

<style>
  .contact-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .subtitle {
    font-size: 1.25rem;
    margin-top: 1rem;
    color: var(--text-muted);
  }

  .contact-content {
    max-width: 600px;
    margin: 2rem auto 0;
  }
</style>
