---
import Layout from "../layouts/Layout.astro";
import InteractiveAvatar from "../components/InteractiveAvatar.astro";
import { getCollection } from "astro:content";
import { formatDate, getSlug } from "../utils/date";
import { calculateReadingTime } from "../utils/readingTime";

// Últim apunt publicat
const posts = (
  await getCollection("blog", ({ data }) => data.draft !== true)
).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const latest = posts[0];
const latestReadingTime = latest?.body ? calculateReadingTime(latest.body) : "";

// Experiència (4 més recents) com a línies de text
const dateOpts: Intl.DateTimeFormatOptions = {
  month: "short",
  year: "numeric",
};
const expLines = (await getCollection("experience"))
  .sort((a, b) => b.data.startDate.valueOf() - a.data.startDate.valueOf())
  .slice(0, 4)
  .map((e) => {
    const start = formatDate(e.data.startDate, dateOpts, "ca-ES");
    const end = e.data.endDate
      ? formatDate(e.data.endDate, dateOpts, "ca-ES")
      : "Actual";
    return `- ${start} — ${end}: ${e.data.role} @ ${e.data.company}`;
  })
  .join("\n");

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Pere Montpeó",
  url: "https://peremontpeo.dev",
  jobTitle: "AI Lead Engineer",
  description: "Enginyer de programari especialitzat en desenvolupament web.",
  sameAs: [
    "https://github.com/pmontp19",
    "https://linkedin.com/in/perem",
    "https://twitter.com/pmontp19",
  ],
};
---

<Layout
  jsonLd={personSchema}
  canonicalUrl="https://peremontpeo.dev/"
  description="Enginyer de programari especialitzat en tot i en res. Actualment, fent que els ordinadors facin coses sols."
>
  <div class="home-avatar animate"><InteractiveAvatar /></div>

  <pre
    class="doc home-doc animate"><span class="title">PERE MONTPEÓ</span> <span class="cursor" aria-hidden="true" />

Enginyer de programari especialitzat en tot i en res. Actualment, fent que els ordinadors facin coses sols. Si no estic programant, segurament em trobaràs sobre la bicicleta, a la cuina o llegint.

<span class="label">STATUS:</span> AI Lead Engineer @ Goil <span class="accent">· Actual</span>

<span class="tilde">~~~</span>

<span class="label">ÚLTIM APUNT:</span>
{latest && (<a class="mdlink" href={`/blog/${getSlug(latest.id)}/`} transition:name={`title-${getSlug(latest.id)}`}>{latest.data.title}</a>)}
<span class="muted">{latest ? `${formatDate(latest.data.date)} · ${latestReadingTime}` : ""}</span>
<a class="mdlink" href="/blog">veure'ls tots →</a>

<span class="tilde">~~~</span>

<span class="label">EXPERIÈNCIA:</span>
{expLines}
<a class="mdlink" href="/experiencia">veure tot →</a>

<span class="tilde">~~~</span>

<span class="label">CONTACTE:</span>
- CORREU    <button id="home-email" class="mdlink email-link" type="button" data-user="pere" data-domain="montpeo.com">correu</button>
- GITHUB    <a class="mdlink" href="https://github.com/pmontp19" target="_blank" rel="noopener noreferrer">github.com/pmontp19</a>
- LINKEDIN  <a class="mdlink" href="https://linkedin.com/in/perem" target="_blank" rel="noopener noreferrer">linkedin.com/in/perem</a>
- TWITTER   <a class="mdlink" href="https://twitter.com/pmontp19" target="_blank" rel="noopener noreferrer">twitter.com/pmontp19</a></pre>
</Layout>

<script is:inline>
  function initHomeEmail() {
    const el = document.getElementById("home-email");
    if (!el || el.dataset.initialized) return;
    const user = el.getAttribute("data-user");
    const domain = el.getAttribute("data-domain");
    if (!user || !domain) return;
    const email = user + "@" + domain;
    el.textContent = email;
    el.addEventListener("click", function () {
      window.location.href = "mailto:" + email;
    });
    el.dataset.initialized = "true";
  }
  document.addEventListener("DOMContentLoaded", initHomeEmail);
  document.addEventListener("astro:page-load", initHomeEmail);
</script>

<style>
  .home-avatar {
    margin-bottom: 24px;
  }

  .email-link {
    font: inherit;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
  }
</style>
