---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import ExperienceEntry from "../components/ExperienceEntry.astro";
import { formatDate, getSlug } from "../utils/date";

const experiences = (await getCollection("experience")).sort(
  (a, b) => b.data.startDate.valueOf() - a.data.startDate.valueOf(),
);

const dateOptions: Intl.DateTimeFormatOptions = {
  month: "long",
  year: "numeric",
};
const locale = "ca-ES";
---

<Layout
  title="Experiència | Pere Montpeó"
  description="Trajectòria professional de Pere Montpeó, enginyer de programari."
  canonicalUrl="https://peremontpeo.dev/experiencia/"
>
  <h1 class="title page-title">EXPERIÈNCIA</h1>
  <a class="mdlink" href="/cv">veure el CV clàssic →</a>

  <p class="tilde" aria-hidden="true">~~~</p>

  {
    experiences.map((exp, index) => (
      <article class="exp-entry">
        <p class="exp-head">
          <span class="title" transition:name={`role-${getSlug(exp.id)}`}>
            {exp.data.role}
          </span>
          <span class="muted"> @ </span>
          <span class="accent" transition:name={`company-${getSlug(exp.id)}`}>
            {exp.data.company}
          </span>
        </p>
        <p class="exp-date muted">
          {formatDate(exp.data.startDate, dateOptions, locale)} —{" "}
          {exp.data.endDate
            ? formatDate(exp.data.endDate, dateOptions, locale)
            : "Actual"}
        </p>

        {exp.data.description && <p class="exp-desc">{exp.data.description}</p>}

        <div class="markdown-content" id={`markdown-content-${index}`}>
          <div class="md-inner">
            <ExperienceEntry data={exp} />
          </div>
        </div>
        {exp.body && exp.body.trim() && (
          <button
            class="show-more-button button-link"
            aria-expanded="false"
            aria-controls={`markdown-content-${index}`}
          >
            <span>veure més</span>
            <span class="arrow-down"> ▼</span>
          </button>
        )}

        {exp.data.tags && exp.data.tags.length > 0 && (
          <p class="exp-tags muted">{exp.data.tags.join(" · ")}</p>
        )}

        <p class="tilde" aria-hidden="true">
          ~~~
        </p>
      </article>
    ))
  }
</Layout>

<script>
  function initializeShowMore() {
    const buttons = document.querySelectorAll(".show-more-button");
    const cleanups: Array<() => void> = [];

    buttons.forEach((button) => {
      const handler = () => {
        const id = button.getAttribute("aria-controls");
        const content = id ? document.getElementById(id) : null;
        const expanded = button.getAttribute("aria-expanded") === "true";
        if (!content) return;
        button.setAttribute("aria-expanded", String(!expanded));
        content.classList.toggle("expanded");
        const label = button.querySelector("span:not(.arrow-down)");
        if (label) label.textContent = expanded ? "veure més" : "veure menys";
      };
      button.addEventListener("click", handler);
      cleanups.push(() => button.removeEventListener("click", handler));
    });

    const cleanup = () => {
      cleanups.forEach((fn) => fn());
      document.removeEventListener("astro:before-swap", cleanup);
    };
    document.addEventListener("astro:before-swap", cleanup, { once: true });
  }

  document.addEventListener("astro:page-load", initializeShowMore);
</script>

<style>
  .page-title {
    font-size: 1.4rem;
    margin: 0 0 0.5rem;
    text-transform: uppercase;
  }

  .exp-entry {
    margin: 0;
  }
  .exp-head {
    margin: 0;
  }
  .exp-date {
    margin: 0 0 0.5rem;
    font-variant-numeric: tabular-nums;
  }
  .exp-desc {
    margin: 0 0 0.5rem;
    max-width: 64ch;
  }
  .exp-tags {
    margin: 0.5rem 0 0;
  }

  .show-more-button {
    margin-top: 0.25rem;
  }
  .arrow-down {
    font-size: 0.7em;
    transition: transform 0.3s ease;
    display: inline-block;
  }
  .show-more-button[aria-expanded="true"] .arrow-down {
    transform: rotate(180deg);
  }

  /* desplegable: anima grid-template-rows 0fr→1fr (alçada exacta, sense salt) */
  .markdown-content {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.35s ease;
  }
  .markdown-content.expanded {
    grid-template-rows: 1fr;
  }
  .md-inner {
    min-height: 0;
    overflow: hidden;
    padding-top: 0.75rem;
  }
  .markdown-content :global(p),
  .markdown-content :global(ul),
  .markdown-content :global(ol) {
    margin-bottom: 0.75rem;
  }
  .markdown-content :global(ul),
  .markdown-content :global(ol) {
    margin-left: 1.5rem;
  }
  .markdown-content :global(li) {
    margin-bottom: 0.35rem;
  }
  .markdown-content :global(strong) {
    font-weight: 600;
  }
  .markdown-content :global(code) {
    font-family: var(--mono);
    background-color: var(--surface);
    padding: 0.1em 0.3em;
    font-size: 0.9em;
  }
</style>
