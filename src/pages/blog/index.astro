---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { formatDate, getSlug } from "../../utils/date";

const allPosts = (
  await getCollection("blog", ({ data }) => {
    return data.draft !== true;
  })
).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout
  title="Apunts - Pere Montpeó"
  description="Apunts, reflexions i tutorials sobre tecnologia, desenvolupament de programari i altres coses que em semblen interessants."
  canonicalUrl="https://peremontpeo.dev/blog/"
>
  <h1 class="title page-title">APUNTS</h1>
  <p class="muted intro">
    Apunts, reflexions i tutorials sobre tecnologia, desenvolupament de
    programari i altres coses que em semblen interessants.
  </p>

  <p class="tilde" aria-hidden="true">~~~</p>

  <ul class="term-list">
    {
      allPosts.map((post) => (
        <li class="term-row">
          <span class="dash muted">-</span>
          <time
            datetime={post.data.date.toISOString()}
            class="row-date muted"
          >
            {formatDate(post.data.date)}
          </time>
          <a
            class="mdlink row-title"
            href={`/blog/${getSlug(post.id)}/`}
          >
            {post.data.title}
          </a>
        </li>
      ))
    }
  </ul>
</Layout>

<style>
  .page-title {
    font-size: 1.4rem;
    margin: 0 0 0.5rem;
    text-transform: uppercase;
  }
  .intro {
    margin: 0;
    max-width: 60ch;
  }

  .term-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .term-row {
    display: grid;
    grid-template-columns: 1.1rem 6.5rem 1fr;
    gap: 0 0.5rem;
    align-items: baseline;
    padding: 2px 0;
  }
  .row-date {
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }
  .row-title {
    overflow-wrap: anywhere;
  }

  @media (max-width: 30rem) {
    .term-row {
      grid-template-columns: 1.1rem 1fr;
    }
    .row-date {
      grid-column: 2;
    }
    .row-title {
      grid-column: 2;
    }
  }
</style>
