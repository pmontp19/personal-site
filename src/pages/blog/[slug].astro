---
import Layout from "../../layouts/Layout.astro";
import { Image } from "astro:assets";
import { getCollection, render } from "astro:content";
import { calculateReadingTime } from "../../utils/readingTime";
import { getSlug } from "../../utils/date";

export async function getStaticPaths() {
  const blogEntries = await getCollection("blog");
  return blogEntries
    .filter((entry) => entry.data.draft !== true)
    .map((entry) => ({
      params: { slug: getSlug(entry.id) },
      props: { entry },
    }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const slug = getSlug(entry.id);

const contentForReadingTime = entry.body || entry.data.description || "";
const readingTime = calculateReadingTime(contentForReadingTime);

const siteUrl = "https://peremontpeo.dev";
const pageUrl = `${siteUrl}/blog/${slug}`;

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: entry.data.title,
  description: entry.data.description,
  datePublished: entry.data.date.toISOString(),
  dateModified:
    entry.data.lastUpdated?.toISOString() ?? entry.data.date.toISOString(),
  author: { "@type": "Person", name: "Pere Montpeó", url: siteUrl },
  publisher: { "@type": "Person", name: "Pere Montpeó", url: siteUrl },
  mainEntityOfPage: { "@type": "WebPage", "@id": pageUrl },
  image: entry.data.image
    ? `${siteUrl}${entry.data.image.src}`
    : `${siteUrl}/api/og-image/${slug}.png`,
};

function formatDate(date: Date): string {
  return new Intl.DateTimeFormat("ca-ES", {
    year: "numeric",
    month: "long",
    day: "numeric",
  }).format(date);
}
---

<Layout
  title={`${entry.data.title} | Pere Montpeó`}
  description={entry.data.description}
  canonicalUrl={pageUrl}
  jsonLd={articleSchema}
>
  <head slot="head">
    <meta
      property="article:published_time"
      content={entry.data.date.toISOString()}
    />
    {
      entry.data.lastUpdated && (
        <meta
          property="article:modified_time"
          content={entry.data.lastUpdated.toISOString()}
        />
      )
    }
    <meta property="article:author" content="Pere Montpeó" />
    <meta property="og:title" content={entry.data.title} />
    <meta property="og:description" content={entry.data.description} />
    <meta property="og:type" content="article" />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:image" content={`${siteUrl}/api/og-image/${slug}.png`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={entry.data.title} />
    <meta name="twitter:description" content={entry.data.description} />
    <meta
      name="twitter:image"
      content={`${siteUrl}/api/og-image/${slug}.png`}
    />
  </head>

  <article class="post">
    <a href="/blog" class="mdlink back">← tornar als apunts</a>
    <h1 class="post-title title">
      {entry.data.title}
    </h1>
    <p class="post-meta muted">
      <time
        datetime={entry.data.date.toISOString()}>{formatDate(entry.data.date)}</time>
      {
        entry.data.lastUpdated && (
          <span> · actualitzat {formatDate(entry.data.lastUpdated)}</span>
        )
      }
      <span> · {readingTime}</span>
    </p>

    {
      entry.data.image && (
        <div class="hero-image">
          <Image
            src={entry.data.image}
            alt={entry.data.imageAlt || entry.data.title}
            widths={[400, 800, 1200]}
            sizes="(max-width: 46rem) 100vw, 46rem"
          />
        </div>
      )
    }

    <p class="tilde" aria-hidden="true">~~~</p>

    <div class="post-content prose">
      <Content />
    </div>

    <p class="tilde" aria-hidden="true">~~~</p>

    <footer class="post-footer">
      <a href="/blog" class="mdlink">← tots els apunts</a>
      <span class="muted share">
        compartir:
        <a
          class="mdlink"
          href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(entry.data.title)}&url=${encodeURIComponent(pageUrl)}`}
          target="_blank"
          rel="noopener noreferrer">twitter</a
        >
        <a
          class="mdlink"
          href={`https://www.linkedin.com/shareArticle?mini=true&url=${encodeURIComponent(pageUrl)}&title=${encodeURIComponent(entry.data.title)}`}
          target="_blank"
          rel="noopener noreferrer">linkedin</a
        >
      </span>
    </footer>
  </article>
</Layout>

<style>
  .post {
    margin: 0 auto;
  }

  .back {
    display: inline-block;
    margin-bottom: 1.5rem;
  }

  .post-title {
    font-size: 1.6rem;
    line-height: 1.2;
    margin: 0 0 0.5rem;
    text-wrap: balance;
  }

  .post-meta {
    font-variant-numeric: tabular-nums;
    margin: 0;
  }

  .hero-image {
    margin: 1.5rem 0 0;
  }
  .hero-image :global(img) {
    width: 100%;
    height: auto;
  }

  /* --- cos de l'article: Geist Sans (excepció de prosa) --- */
  .post-content {
    font-size: 1.0625rem;
  }
  .post-content :global(h2) {
    font-size: 1.4rem;
    font-weight: 600;
    margin: 2rem 0 0.75rem;
  }
  .post-content :global(h3) {
    font-size: 1.15rem;
    font-weight: 600;
    margin: 1.5rem 0 0.5rem;
  }
  .post-content :global(p) {
    margin: 0 0 1.15rem;
  }
  .post-content :global(a) {
    color: var(--accent);
    text-decoration: underline;
  }
  .post-content :global(ul),
  .post-content :global(ol) {
    margin: 0 0 1.15rem;
    padding-left: 1.5rem;
  }
  .post-content :global(li) {
    margin-bottom: 0.4rem;
  }
  .post-content :global(pre) {
    background-color: var(--surface);
    padding: 1rem;
    margin: 1.5rem 0;
    overflow-x: auto;
    border: 1px solid var(--line);
  }
  .post-content :global(code) {
    font-family: var(--mono);
    font-size: 0.85em;
  }
  .post-content :global(:not(pre) > code) {
    background-color: var(--surface);
    padding: 0.1em 0.35em;
  }
  .post-content :global(blockquote) {
    border-left: 2px solid var(--accent);
    padding-left: 1rem;
    color: var(--muted);
    margin: 1.5rem 0;
  }
  .post-content :global(img) {
    max-width: 100%;
    height: auto;
    margin: 1.5rem 0;
  }
  .post-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
  }
  .post-content :global(table th),
  .post-content :global(table td) {
    padding: 0.5rem;
    border: 1px solid var(--line);
    text-align: left;
  }
  .post-content :global(.external-link) {
    display: inline-flex;
    align-items: center;
    gap: 0.25em;
  }
  .post-content :global(.external-link-icon) {
    width: 0.85em;
    height: 0.85em;
  }

  .post-footer {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 0.5rem 1rem;
  }
  .share {
    display: inline-flex;
    gap: 0.6rem;
    flex-wrap: wrap;
  }
</style>
