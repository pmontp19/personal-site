---
import { getCollection } from "astro:content";
import MagicCard from "./MagicCard.astro";
import { formatDate, getSlug } from "../utils/date";
import { calculateReadingTime } from "../utils/readingTime";

const allPosts = (
  await getCollection("blog", ({ data }) => {
    return data.draft !== true;
  })
).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const featuredPost = allPosts[0];

const readingTime = featuredPost
  ? calculateReadingTime(featuredPost.body)
  : "";
---

<section id="apunts" class="section blog-section animate">
  <div class="section-header">
    <h2>Últim apunt</h2>
    <a href="/blog" class="view-all-link-text button-link">Veure tots →</a>
  </div>

  {featuredPost && (
    <MagicCard class="featured-post-card">
      <div class="post-content">
        <div class="post-meta text-muted">
          <time datetime={featuredPost.data.date.toISOString()} transition:name={`date-${getSlug(featuredPost.id)}`}>
            {formatDate(featuredPost.data.date)}
          </time>
          <span class="reading-time">⌛ {readingTime}</span>
        </div>
        <h3 class="post-title" transition:name={`title-${getSlug(featuredPost.id)}`}>
          <a href={`/blog/${getSlug(featuredPost.id)}`}>{featuredPost.data.title}</a>
        </h3>
        <p class="post-description text-muted">{featuredPost.data.description}</p>
      </div>
      <a href={`/blog/${getSlug(featuredPost.id)}`} class="read-more button-link">
        Llegir més →
      </a>
    </MagicCard>
  )}
</section>

<style>
  h2 {
    margin-bottom: 0;
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 1.5rem;
    gap: 1rem;
  }

  .featured-post-card {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .post-content {
    flex-grow: 1;
    margin-bottom: 1rem;
  }

  .post-meta {
    font-size: 0.875rem;
    margin-bottom: 0.5rem;
    display: flex;
    gap: 0.75rem;
    align-items: center;
  }

  .post-title {
    font-size: 1.25rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  .post-title a {
    color: inherit;
    text-decoration: none;
  }

  .post-title a:hover {
    text-decoration: underline;
  }

  .post-description {
    font-size: 0.95rem;
    line-height: 1.5;
  }

  .read-more {
    margin-top: auto;
    align-self: flex-start;
  }
</style>
