---
const emailUser = "pere";
const emailDomain = "montpeo.com";

const socialLinks = [
  {
    name: "github.com/pmontp19",
    url: "https://github.com/pmontp19",
    label: "GITHUB",
  },
  {
    name: "linkedin.com/in/perem",
    url: "https://linkedin.com/in/perem",
    label: "LINKEDIN",
  },
  {
    name: "twitter.com/pmontp19",
    url: "https://twitter.com/pmontp19",
    label: "TWITTER",
  },
];
---

<ul class="contact-list">
  <li class="contact-row">
    <span class="dash muted">-</span>
    <span class="ck label">CORREU</span>
    <button
      id="email-link-placeholder"
      class="mdlink email-link"
      type="button"
      data-user={emailUser}
      data-domain={emailDomain}>correu</button
    >
  </li>
  {
    socialLinks.map((link) => (
      <li class="contact-row">
        <span class="dash muted">-</span>
        <span class="ck label">{link.label}</span>
        <a
          class="mdlink"
          href={link.url}
          target="_blank"
          rel="noopener noreferrer"
        >
          {link.name}
        </a>
      </li>
    ))
  }
</ul>

<script is:inline>
  function initContactEmail() {
    const el = document.getElementById("email-link-placeholder");
    if (!el || el.dataset.initialized) return;
    const user = el.getAttribute("data-user");
    const domain = el.getAttribute("data-domain");
    if (!user || !domain) return;
    const email = `${user}@${domain}`;
    el.textContent = email;
    el.addEventListener("click", () => {
      window.location.href = `mailto:${email}`;
    });
    el.dataset.initialized = "true";
  }
  document.addEventListener("DOMContentLoaded", initContactEmail);
  document.addEventListener("astro:page-load", initContactEmail);
</script>

<style>
  .contact-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .contact-row {
    display: grid;
    grid-template-columns: 1.1rem 6rem 1fr;
    gap: 0 0.5rem;
    align-items: baseline;
    padding: 2px 0;
  }
  .email-link {
    font: inherit;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    text-align: left;
    overflow-wrap: anywhere;
  }
  @media (max-width: 30rem) {
    .contact-row {
      grid-template-columns: 1.1rem 1fr;
    }
    .ck,
    .contact-row a,
    .email-link {
      grid-column: 2;
    }
  }
</style>
