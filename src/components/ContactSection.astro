---
const emailUser = "pere";
const emailDomain = "montpeo.com";

const socialLinks = [
  { name: "GitHub", url: "https://github.com/pmontp19", icon: "github" },
  { name: "LinkedIn", url: "https://linkedin.com/in/perem", icon: "linkedin" },
  { name: "Twitter", url: "https://twitter.com/pmontp19", icon: "twitter" },
];
---

<div class="contact-grid">
  <div class="contact-email">
    <h3>Correu Electrònic</h3>
    <button
      id="email-link-placeholder"
      class="button-link"
      type="button"
      data-user={emailUser}
      data-domain={emailDomain}
    >
      Carregant correu\u2026
    </button>
  </div>

  <div class="contact-social">
    <h3>Xarxes Socials</h3>
    <ul class="social-links-list">
      {
        socialLinks.map((link) => (
          <li>
            <a
              href={link.url}
              target="_blank"
              rel="noopener noreferrer"
              class="button-link"
            >
              {link.icon === "github" && (
                <svg
                  aria-hidden="true"
                  viewBox="0 0 16 16"
                  width="20"
                  height="20"
                  fill="currentColor"
                >
                  <path
                    fill-rule="evenodd"
                    d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82a7.65 7.65 0 012-.27c.68.003 1.36.092 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"
                  />
                </svg>
              )}
              {link.icon === "linkedin" && (
                <svg
                  aria-hidden="true"
                  viewBox="0 0 24 24"
                  width="20"
                  height="20"
                  fill="currentColor"
                >
                  <path d="M20.447 20.452H17.2v-5.569c0-1.327-.028-3.037-1.849-3.037-1.85 0-2.134 1.445-2.134 2.939v5.667H10.6V9h3.1v1.561h.045c.431-.81 1.486-1.665 3.055-1.665 3.268 0 3.872 2.151 3.872 4.944v6.612zM5.337 7.433a1.8 1.8 0 11-.001-3.6 1.8 1.8 0 01.001 3.6zm1.697 13.019H3.64V9h3.394v11.452zM22.225 0H1.771C.792 0 0 .771 0 1.723v20.554C0 23.229.792 24 1.771 24h20.451C23.2 24 24 23.229 24 22.277V1.723C24 .771 23.2 0 22.225 0z" />
                </svg>
              )}
              {link.icon === "twitter" && (
                <svg
                  aria-hidden="true"
                  viewBox="0 0 24 24"
                  width="20"
                  height="20"
                  fill="currentColor"
                >
                  <path d="M13.795 10.533 20.68 2h-3.073l-5.255 6.517L7.69 2H1l7.806 10.91L1.47 22h3.074l5.705-7.07L15.31 22H22l-8.205-11.467Zm-2.38 2.95L9.97 11.464 4.36 3.627h2.31l4.528 6.317 1.443 2.02 6.018 8.409h-2.31l-4.934-6.89Z" />
                </svg>
              )}
              {link.name}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</div>

<script is:inline>
  function initContactEmail() {
    const placeholder = document.getElementById("email-link-placeholder");
    if (placeholder && !placeholder.dataset.initialized) {
      const user = placeholder.getAttribute("data-user");
      const domain = placeholder.getAttribute("data-domain");
      if (user && domain) {
        const email = `${user}@${domain}`;
        placeholder.textContent = email;
        placeholder.addEventListener("click", () => {
          window.location.href = `mailto:${email}`;
        });
        placeholder.dataset.initialized = "true";
      }
    }
  }
  document.addEventListener("DOMContentLoaded", initContactEmail);
  document.addEventListener("astro:page-load", initContactEmail);
</script>

<style>
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  @media (min-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  h3 {
    margin-bottom: 0.5rem;
  }

  .social-links-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .social-links-list li {
    margin-bottom: 0;
  }
</style>
