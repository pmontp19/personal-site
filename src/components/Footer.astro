---
const year = new Date().getFullYear();
const { pathname } = Astro.url;
const isHome = pathname === "/";
const isBlog = pathname.startsWith("/blog");
const isCv = pathname.startsWith("/cv");
---

<footer class="site-footer">
  <p class="tilde" aria-hidden="true">~~~</p>
  <nav class="foot-line" aria-label="Navegació">
    <span class="muted">© {year} Pere Montpeó · </span>
    <a class="mdlink" href="/" aria-current={isHome ? "page" : undefined}>inici</a>
    <a class="mdlink" href="/blog" aria-current={isBlog ? "page" : undefined}>apunts</a>
    <a class="mdlink" href="/cv" aria-current={isCv ? "page" : undefined}>cv</a>
  </nav>
  <p class="foot-line">
    <span class="label">TEMA:</span>
    <button id="light-theme-button" class="theme-opt" type="button" aria-label="Tema clar">clar</button>
    <span class="muted">/</span>
    <button id="dark-theme-button" class="theme-opt" type="button" aria-label="Tema fosc">fosc</button>
    <span class="muted">/</span>
    <button id="system-theme-button" class="theme-opt" type="button" aria-label="Tema del sistema">auto</button>
  </p>
</footer>

<style>
  .site-footer {
    flex-shrink: 0;
    margin-top: 40px;
  }

  .foot-line {
    margin: 0 0 4px;
  }

  [aria-current="page"].mdlink {
    color: var(--fg);
  }
  [aria-current="page"].mdlink::before,
  [aria-current="page"].mdlink::after {
    color: var(--accent);
  }

  .theme-opt {
    font: inherit;
    background: none;
    border: none;
    padding: 0;
    color: var(--accent);
    cursor: pointer;
  }
  .theme-opt:hover,
  .theme-opt:focus-visible {
    text-decoration: underline;
  }
  .theme-opt:focus-visible {
    outline: 1px solid var(--accent);
    outline-offset: 2px;
  }

  @media print {
    .site-footer {
      display: none;
    }
  }
</style>
