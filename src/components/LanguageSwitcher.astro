---
interface Props {
  currentLang: string;
}

const { currentLang } = Astro.props;
---

<div class="language-switcher">
  <a
    href="/cv/ca"
    class:list={["lang-link", { active: currentLang === "ca" }]}
    aria-current={currentLang === "ca" ? "page" : undefined}
  >
    Català
  </a>
  <span class="separator">|</span>
  <a
    href="/cv/en"
    class:list={["lang-link", { active: currentLang === "en" }]}
    aria-current={currentLang === "en" ? "page" : undefined}
  >
    English
  </a>
</div>

<style>
  .language-switcher {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
    font-size: 0.9rem;
  }

  .lang-link {
    color: var(--text-muted);
    text-decoration: none;
    padding: 0.25rem 0.5rem;
    border-radius: var(--radius);
    transition:
      color 0.2s ease,
      background-color 0.2s ease;
  }

  .lang-link:hover {
    color: var(--primary);
    background-color: var(--secondary);
  }

  .lang-link.active {
    color: var(--foreground);
    font-weight: 600;
    background-color: var(--secondary);
  }

  .separator {
    color: var(--text-muted);
    user-select: none;
  }
</style>
